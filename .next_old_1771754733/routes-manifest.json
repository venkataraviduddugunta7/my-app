    },
    {
      "page": "/rooms",
      "regex": "^/rooms(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/rooms(?:/)?$"
    },
    {
      "page": "/settings",
      "regex": "^/settings(?:/)?$",
