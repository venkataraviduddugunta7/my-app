      "routeKeys": {},
      "namedRegex": "^/payments(?:/)?$"
    },
    {
      "page": "/properties",
      "regex": "^/properties(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/properties(?:/)?$"
    },
    {
      "page": "/reports",
      "regex": "^/reports(?:/)?$",
      "routeKeys": {},
